# ---- Database (PostgreSQL for production / Vercel) ----
# Vercel Postgres, Neon, Supabase, or Railway all work. Example (Neon):
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# ---- Auth ----
# Signs guest & admin session cookies (JWT). Use a long random string in production.
AUTH_SECRET="change-me-to-a-long-random-string"

# ---- Default admin (used only by the seed script) ----
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="balance123"

# ---- Optional: Telegram new-reservation alerts (leave blank to disable) ----
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""
