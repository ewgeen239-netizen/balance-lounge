# ---- Database (PostgreSQL for production / Vercel) ----
# Vercel Postgres, Neon, Supabase, or Railway all work. Example (Neon):
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# ---- Auth ----
# Signs guest & admin session cookies (JWT). Use a long random string in production.
AUTH_SECRET="change-me-to-a-long-random-string"

# ---- Default admin (used only by the seed script) ----
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="balance123"

# ---- Optional: Telegram new-reservation alerts (leave blank to disable) ----
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# ---- Optional: SMSAPI.pl confirmation SMS to the guest (leave blank to disable) ----
# Token from https://ssl.smsapi.pl → Settings → API tokens (OAuth access token).
SMSAPI_TOKEN=""
# Approved sender name (e.g. "Balance"). Leave blank to use SMSAPI's default sender.
SMSAPI_SENDER=""

# ---- Vercel Blob (image uploads) ----
# Auto-added by Vercel when you connect a Blob store. Leave blank locally to fall
# back to writing uploads into public/uploads.
BLOB_READ_WRITE_TOKEN=""
